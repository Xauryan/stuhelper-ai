{
  "name": "StuHelper AI-electron",
  "version": "1.0.0",
  "description": "StuHelper AI - AI Model Gateway Desktop Application",
  "main": "main.js",
  "scripts": {
    "start-app": "electron .",
    "dev-app": "cross-env NODE_ENV=development electron .",
    "build": "electron-builder",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux"
  },
  "keywords": [
    "ai",
    "api",
    "gateway",
    "openai",
    "claude"
  ],
  "author": "Xauryan",
  "repository": {
    "type": "git",
    "url": "https://github.com/Xauryan/stuhelper-ai"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "electron": "39.8.5",
    "electron-builder": "^26.7.0"
  },
  "build": {
    "appId": "com.stuhelper-ai.desktop",
    "productName": "StuHelper AI-App",
    "publish": null,
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "icon.png",
      "tray-iconTemplate.png",
      "tray-iconTemplate@2x.png",
      "tray-icon-windows.png"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "icon.png",
      "identity": null,
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "entitlements": "entitlements.mac.plist",
      "entitlementsInherit": "entitlements.mac.plist",
      "target": [
        "dmg",
        "zip"
      ],
      "extraResources": [
        {
          "from": "../StuHelper AI",
          "to": "bin/StuHelper AI"
        },
        {
          "from": "../web/dist",
          "to": "web/dist"
        },
        {
          "from": "../LICENSE",
          "to": "licenses/LICENSE"
        },
        {
          "from": "../NOTICE",
          "to": "licenses/NOTICE"
        },
        {
          "from": "../THIRD-PARTY-LICENSES.md",
          "to": "licenses/THIRD-PARTY-LICENSES.md"
        },
        {
          "from": "node_modules/electron/dist/LICENSE",
          "to": "licenses/electron/LICENSE"
        },
        {
          "from": "node_modules/electron/dist/LICENSES.chromium.html",
          "to": "licenses/electron/LICENSES.chromium.html"
        }
      ]
    },
    "win": {
      "icon": "icon.png",
      "target": [
        "nsis",
        "portable"
      ],
      "extraResources": [
        {
          "from": "../StuHelper AI.exe",
          "to": "bin/StuHelper AI.exe"
        },
        {
          "from": "../LICENSE",
          "to": "licenses/LICENSE"
        },
        {
          "from": "../NOTICE",
          "to": "licenses/NOTICE"
        },
        {
          "from": "../THIRD-PARTY-LICENSES.md",
          "to": "licenses/THIRD-PARTY-LICENSES.md"
        },
        {
          "from": "node_modules/electron/dist/LICENSE",
          "to": "licenses/electron/LICENSE"
        },
        {
          "from": "node_modules/electron/dist/LICENSES.chromium.html",
          "to": "licenses/electron/LICENSES.chromium.html"
        }
      ]
    },
    "linux": {
      "icon": "icon.png",
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Development",
      "extraResources": [
        {
          "from": "../StuHelper AI",
          "to": "bin/StuHelper AI"
        },
        {
          "from": "../LICENSE",
          "to": "licenses/LICENSE"
        },
        {
          "from": "../NOTICE",
          "to": "licenses/NOTICE"
        },
        {
          "from": "../THIRD-PARTY-LICENSES.md",
          "to": "licenses/THIRD-PARTY-LICENSES.md"
        },
        {
          "from": "node_modules/electron/dist/LICENSE",
          "to": "licenses/electron/LICENSE"
        },
        {
          "from": "node_modules/electron/dist/LICENSES.chromium.html",
          "to": "licenses/electron/LICENSES.chromium.html"
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
